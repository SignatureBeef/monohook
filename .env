# Default environment variables for clrhook build
# (Override in .env.override for user-specific settings)

# Example:

# Stardew Valley (net6.0) on Linux:
# DESTINATION_PATH="/SteamLibrary/steamapps/common/Stardew Valley"
# TARGET_RUNTIME="net6.0"

# Terraria (net4.0) on Linux:
# DESTINATION_PATH="/SteamLibrary/steamapps/common/Terraria"
# TARGET_RUNTIME="net40"

# Terraria (net4.0) on Apple:
# DESTINATION_PATH="/Users/username/Library/Application Support/Steam/steamapps/common/Terraria/Terraria.app/Contents/"
# TARGET_RUNTIME="net40"
